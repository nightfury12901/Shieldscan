{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/index.html"
    }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@latest",
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
