# ─────────────────────────────────────────────
# SUPABASE
# ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────────
# AI (Groq)
# model: llama3-70b-8192 (fallback: llama3-8b-8192)
# ─────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here

# ─────────────────────────────────────────────
# EXTERNAL SCAN APIs
# ─────────────────────────────────────────────
# HaveIBeenPwned — https://haveibeenpwned.com/API/Key
HIBP_API_KEY=your-hibp-api-key-here

# Google Safe Browsing — https://developers.google.com/safe-browsing
GOOGLE_SAFE_BROWSING_API_KEY=your-google-safe-browsing-api-key-here

# WPScan — https://wpscan.com/api (free: 25 scans/day)
WPSCAN_API_KEY=your-wpscan-api-key-here

# NVD CVE — https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your-nvd-api-key-here

# GitHub — for GitHub API rate limits (optional, public repos work without)
GITHUB_TOKEN=your-github-token-here

# OWASP ZAP — optional; if not set, pure-Python XSS/SQLi probe is used
ZAP_API_URL=

# ─────────────────────────────────────────────
# VERCEL / CORS
# Set this to your deployed Vercel frontend URL
# ─────────────────────────────────────────────
FRONTEND_URL=https://your-project.vercel.app

# ─────────────────────────────────────────────
# FRONTEND (Vite — prefix with VITE_)
# Copy these into your Vercel project env vars
# ─────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_API_BASE_URL=

# ─────────────────────────────────────────────
# PAYMENTS (Razorpay)
# ─────────────────────────────────────────────
# Razorpay
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_SDidaBhr5VrOxF
RAZORPAY_KEY_SECRET=AtpzbVvqPWl3FBKSKelkDQDU
